# --- Supabase (mismo proyecto que Thinkia_Call_Experience) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Recomendado en servidor (Vercel): lectura/escritura sin sesión de usuario
SUPABASE_SERVICE_ROLE_KEY=

# Compatibilidad con variables del proyecto Next (opcional; el servidor las acepta igual)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
# Cuenta en UE / Irlanda (opcional; si no, Twilio usa US por defecto)
# TWILIO_REGION=ie1
# TWILIO_EDGE=dublin
TWILIO_TWIML_APP_SID=
# Número Twilio verificado para Caller ID en salientes (Client → PSTN)
TWILIO_CALLER_ID=

# --- ElevenLabs ---
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# --- Enrutamiento entrante (opcional) ---
# INBOUND_AGENT_IDENTITIES=agente_thinkia_com,laura_soporte_thinkia_com
# INBOUND_NUMBER_AGENT_MAP={"+34123456789":["agente_thinkia_com"]}

# API local (solo si el front no está en el mismo origen)
# VITE_PUBLIC_API_URL=

# URL pública del backend (sin barra final). Twilio usará esto en TwiML para callbacks de grabación.
# En Vercel suele bastar VERCEL_URL; si no, define explícitamente:
# PUBLIC_APP_URL=https://tu-proyecto.vercel.app

# Centro de llamadas: `true` para historial real (Twilio). Si no, datos demo en la UI.
# VITE_USE_LIVE_CALLS=true
