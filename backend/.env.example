# Twilio Console → Account
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Console → Account → API keys & tokens → Create API Key
# TWILIO_API_KEY = API Key SID (starts with SK...)
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_api_key_secret

# Twilio Console → Develop → Tools → TwiML Apps → your Voice app
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Console → Develop → Voice → Push credentials (CR...)
# iOS and Android typically need separate credentials in Twilio.
TWILIO_PUSH_CREDENTIAL_SID_IOS=
TWILIO_PUSH_CREDENTIAL_SID_ANDROID=

# Caller ID for outbound PSTN (verified Twilio number, E.164)
TWILIO_CALLER_ID=

# Reserva si no hay mapa INBOUND_*: identidad Client (debe existir un usuario app con ese id)
DEFAULT_INBOUND_CLIENT_IDENTITY=pedro_castro

# Opcional: {"+34900111222":"u_abc...","+34900333444":"u_def..."} — PSTN al número → Client identity
INBOUND_TO_CLIENT_IDENTITY_JSON=

# Opcional: secreto para POST /test/ring-mobile (Twilio llama a client:identidad en la app)
RING_TEST_SECRET=

# Server
PORT=3000
